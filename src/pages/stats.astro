---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const blog = await getCollection("blog");
const projects = await getCollection("projects");
const systems = await getCollection("systems");
const benchmarks = await getCollection("benchmarks");

const publishedBlog = blog.filter((e) => e.data.status === "published");
const publishedBenchmarks = benchmarks.filter(
    (e) => e.data.status === "published",
);

const allEntries = [...blog, ...projects, ...systems, ...benchmarks];

const stripMarkdown = (text: string) =>
    text
        .replace(/```[\s\S]*?```/g, "")
        .replace(/`[^`]*`/g, "")
        .replace(/!\[[^\]]*\]\([^)]+\)/g, "")
        .replace(/\[[^\]]*\]\([^)]+\)/g, "")
        .replace(/[#>*_\-\n\r]/g, " ")
        .replace(/\s+/g, " ")
        .trim();

const countWords = (text: string) =>
    text.length === 0 ? 0 : text.split(" ").filter(Boolean).length;

const totalWrittenWords = allEntries.reduce(
    (sum, entry) => sum + countWords(stripMarkdown(entry.body ?? "")),
    0,
);

const dates: Date[] = allEntries.flatMap((entry) => {
    const out: Date[] = [];
    if ("date" in entry.data && entry.data.date instanceof Date)
        out.push(entry.data.date);
    if ("updated" in entry.data && entry.data.updated instanceof Date)
        out.push(entry.data.updated);
    return out;
});

const latestContentUpdate =
    dates.length > 0
        ? new Date(Math.max(...dates.map((d) => d.getTime())))
        : null;

const formatDate = (d: Date | null) =>
    d ? d.toISOString().slice(0, 10) : "N/A";

const tagCounts = new Map<string, number>();
for (const entry of allEntries) {
    const tags = "tags" in entry.data ? (entry.data.tags ?? []) : [];
    for (const tag of tags) {
        tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
    }
}

const mostUsedTags = [...tagCounts.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, 20);

const featuredProjectCount = projects.filter((p) => p.data.featured).length;

const contentRows = [
    ["Published articles", publishedBlog.length],
    ["Projects", projects.length],
    ["Systems notes", systems.length],
    ["Benchmark entries", publishedBenchmarks.length],
    ["Featured projects", featuredProjectCount],
];

const writingRows = [["Total written words", totalWrittenWords]];

const freshnessRows = [
    ["Latest content update", formatDate(latestContentUpdate)],
];
---

<BaseLayout title="Stats">
    <h1>Stats</h1>
    <p class="lede">Build-time content metadata from this repository.</p>

    <section>
        <h2>Content Counts</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Metric</th>
                        <th class="num">Value</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        contentRows.map(([label, value]) => (
                            <tr>
                                <td>{label}</td>
                                <td class="num">{value}</td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section>
        <h2>Writing Volume</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Metric</th>
                        <th class="num">Value</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        writingRows.map(([label, value]) => (
                            <tr>
                                <td>{label}</td>
                                <td class="num">{value}</td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section>
        <h2>Freshness</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Metric</th>
                        <th class="num">Value</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        freshnessRows.map(([label, value]) => (
                            <tr>
                                <td>{label}</td>
                                <td class="num">{value}</td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section>
        <h2>Tag Distribution</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Tag</th>
                        <th class="num">Uses</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        mostUsedTags.map(([tag, count]) => (
                            <tr>
                                <td>{tag}</td>
                                <td class="num">{count}</td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
        <p class="small">
            Top {mostUsedTags.length} tags by frequency.
        </p>
    </section>
</BaseLayout>
